    "@tanstack/react-table": "^8.21.3",
    "@turf/turf": "^7.3.5",
    "adm-zip": "^0.6.0",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "geojson-validation": "^1.0.2",
    "jose": "^6.2.3",
    "jszip": "^3.10.1",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.10",
    "papaparse": "^5.5.4",
    "proj4": "^2.20.9",
